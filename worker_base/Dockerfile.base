FROM python:3.10-slim

WORKDIR /app

# System dependencies (chung cho tất cả worker)
RUN apt-get update && apt-get install -y \
    ffmpeg \
    imagemagick \
    libsm6 \
    libxext6 \
    && rm -rf /var/lib/apt/lists/*

# Fix ImageMagick
RUN sed -i 's/none/read,write/g' /etc/ImageMagick-6/policy.xml || true

# Copy uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
COPY worker_base/requirements-base.txt .
RUN uv pip install --system --no-cache -r requirements-base.txt

ENV PYTHONPATH=/app